{
  "$schema": "https://schemas.unbound24.com/design-tokens/1.0.json",
  "client": "french-roofing",
  "spec-version": "2.1",
  "last-updated": "2026-05-06",
  "color": {
    "brand": {
      "primary": { "value": "#ffbd59", "use": "Primary CTAs, highlights, accents (Yellow)" },
      "secondary": { "value": "#d85024", "use": "Secondary CTAs, hover states, emphasis, focus rings (Orange)" },
      "tertiary": { "value": "#092e5e", "use": "Headings, deep backgrounds, button text on yellow, trust elements (Blue)" },
      "neutral": { "value": "#3e3d3b", "use": "Body text (Grey)" }
    },
    "surface": {
      "bg": { "value": "#fdfcfa", "use": "Warm off-white page background" },
      "surface": { "value": "#f5f1ea", "use": "Cream cards / raised sections" },
      "surface-alt": { "value": "#ffffff", "use": "Pure white for inputs and contrast" }
    },
    "text": {
      "primary": { "value": "#3e3d3b", "use": "Body" },
      "secondary": { "value": "#6b6a67", "use": "Subheads, secondary copy" },
      "muted": { "value": "#9a9895", "use": "Captions, metadata" },
      "inverse": { "value": "#fdfcfa", "use": "Text on dark surfaces" }
    },
    "border": {
      "default": { "value": "#e5e0d6", "use": "Card / input / divider borders" },
      "strong": { "value": "#c9c2b3", "use": "Heavier separation when needed" }
    },
    "status": {
      "success": { "value": "#4a7c4e", "use": "Confirmations" },
      "warning": { "value": "#d85024", "use": "Same as secondary" },
      "error": { "value": "#b8341c", "use": "Form errors" }
    }
  },
  "typography": {
    "family": {
      "default": "'Inter', system-ui, -apple-system, sans-serif"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "size": {
      "display": { "px": 56, "rem": "3.5rem" },
      "h1": { "px": 40, "rem": "2.5rem" },
      "h2": { "px": 32, "rem": "2rem" },
      "h3": { "px": 24, "rem": "1.5rem" },
      "h4": { "px": 20, "rem": "1.25rem" },
      "body": { "px": 17, "rem": "1.0625rem" },
      "small": { "px": 15, "rem": "0.9375rem" },
      "caption": { "px": 13, "rem": "0.8125rem" }
    },
    "line-height": {
      "tight": 1.05,
      "snug": 1.2,
      "normal": 1.5,
      "relaxed": 1.6
    },
    "letter-spacing": {
      "tight": "-0.02em",
      "snug": "-0.01em",
      "wide": "0.05em"
    },
    "scale": {
      "display": { "size": "display", "line-height": "tight",   "tracking": "tight", "weight": 700 },
      "h1":      { "size": "h1",      "line-height": 1.15,      "tracking": "snug",  "weight": 700 },
      "h2":      { "size": "h2",      "line-height": "snug",    "tracking": null,    "weight": 600 },
      "h3":      { "size": "h3",      "line-height": 1.3,       "tracking": null,    "weight": 600 },
      "h4":      { "size": "h4",      "line-height": 1.4,       "tracking": null,    "weight": 500 },
      "body":    { "size": "body",    "line-height": "relaxed", "tracking": null,    "weight": 400 },
      "small":   { "size": "small",   "line-height": "normal",  "tracking": null,    "weight": 400 },
      "caption": { "size": "caption", "line-height": 1.4,       "tracking": "wide",  "weight": 500, "transform": "uppercase" }
    }
  },
  "spacing": {
    "base": "4px",
    "scale": {
      "1": { "px": 4,   "rem": "0.25rem" },
      "2": { "px": 8,   "rem": "0.5rem" },
      "3": { "px": 12,  "rem": "0.75rem" },
      "4": { "px": 16,  "rem": "1rem" },
      "6": { "px": 24,  "rem": "1.5rem" },
      "8": { "px": 32,  "rem": "2rem" },
      "12": { "px": 48, "rem": "3rem" },
      "16": { "px": 64, "rem": "4rem" },
      "24": { "px": 96, "rem": "6rem" },
      "32": { "px": 128, "rem": "8rem" }
    }
  },
  "radius": {
    "sm": { "value": "4px", "use": "images, small elements" },
    "md": { "value": "8px", "use": "buttons, inputs" },
    "lg": { "value": "12px", "use": "cards" },
    "pill": { "value": "999px", "use": "badges only" }
  },
  "shadow": {
    "sm": "0 1px 2px rgba(9, 46, 94, 0.04)",
    "md": "0 4px 12px rgba(9, 46, 94, 0.06)",
    "lg": "0 12px 32px rgba(9, 46, 94, 0.08)"
  },
  "layout": {
    "container-max": "1200px",
    "section-padding-y-desktop": "var(--space-24)",
    "section-padding-y-mobile": "var(--space-12)",
    "mode": "light"
  },
  "components": {
    "button-primary": "Solid #ffbd59 fill, #092e5e text, 8px radius, 12px/20px padding, no shadow, subtle hover lift",
    "button-secondary": "Outlined #092e5e, transparent fill, 8px radius",
    "card": "#f5f1ea on #fdfcfa, 12px radius, 1px #e5e0d6 border, no shadow, 24-32px internal padding",
    "input": "White fill, 1px #e5e0d6 border, 8px radius, focus border #d85024",
    "table": "No zebra, 1px bottom borders only, 56px+ row height",
    "image": "Real PNW crews, natural light, 4-8px radius, no filters or duotones"
  }
}
